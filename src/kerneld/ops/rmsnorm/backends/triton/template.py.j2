# Generated by kerneld for $candidate_id.
from __future__ import annotations

import torch
import triton
import triton.language as tl

HIDDEN_SIZE = $hidden_size
BLOCK_SIZE = $block_size
NUM_WARPS = $num_warps
DTYPE_LABEL = "$dtype_label"


@triton.jit
def _rmsnorm_kernel(x_ptr, weight_ptr, y_ptr, n_cols: tl.constexpr, eps: tl.constexpr, block_size: tl.constexpr):
    row_idx = tl.program_id(0)
    offsets = tl.arange(0, block_size)
    mask = offsets < n_cols
    x = tl.load(x_ptr + row_idx * n_cols + offsets, mask=mask, other=0.0).to(tl.float32)
    weight = tl.load(weight_ptr + offsets, mask=mask, other=0.0)
    variance = tl.sum(x * x, axis=0) / n_cols
    y = (x * tl.rsqrt(variance + eps)).to($output_dtype) * weight
    tl.store(y_ptr + row_idx * n_cols + offsets, y, mask=mask)


def kernel_fn(x: torch.Tensor, weight: torch.Tensor, eps: float) -> torch.Tensor:
    if x.shape[-1] != HIDDEN_SIZE:
        raise ValueError(f"expected hidden size {HIDDEN_SIZE}, got {x.shape[-1]}")
    x_contiguous = x.contiguous()
    weight_contiguous = weight.contiguous()
    y = torch.empty_like(x_contiguous)
    rows = x_contiguous.numel() // HIDDEN_SIZE
    _rmsnorm_kernel[(rows,)](
        x_contiguous,
        weight_contiguous,
        y,
        HIDDEN_SIZE,
        float(eps),
        block_size=BLOCK_SIZE,
        num_warps=NUM_WARPS,
    )
    return y.reshape_as(x)
